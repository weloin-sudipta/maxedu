{
    "doctype": "DocType",
    "name": "Library Book Inventory",
    "module": "Maxedu",
    "istable": 0,
    "autoname": "field:book",
    "naming_rule": "By fieldname",
    "field_order": [
        "book",
        "copy_type",
        "is_issued",
        "column_break_1",
        "status",
        "added_by",
        "section_physical",
        "total_copies",
        "available_copies",
        "location",
        "column_break_2",
        "borrow_period_days",
        "fine_per_day",
        "section_online",
        "ebook_file"
    ],
    "fields": [
        {
            "fieldname": "book",
            "fieldtype": "Link",
            "label": "Book",
            "options": "Library Book",
            "reqd": 1,
            "in_list_view": 1,
            "get_query": null,
            "fieldtype_options": {},
            "fetch_from": "",
            "description": "",
            "label_field": "title"
        },
        {
            "fieldname": "copy_type",
            "fieldtype": "Select",
            "label": "Copy Type",
            "options": "Physical\nOnline",
            "reqd": 1,
            "in_list_view": 1
        },
        {
            "fieldname": "is_issued",
            "fieldtype": "Check",
            "label": "Is Issued",
            "default": 0,
            "read_only": 1
        },
        {
            "fieldname": "column_break_1",
            "fieldtype": "Column Break"
        },
        {
            "fieldname": "status",
            "fieldtype": "Select",
            "label": "Status",
            "options": "Available\nUnavailable\nReserved",
            "default": "Available"
        },
        {
            "fieldname": "added_by",
            "fieldtype": "Link",
            "label": "Added By",
            "options": "User",
            "read_only": 1
        },
        {
            "fieldname": "section_physical",
            "fieldtype": "Section Break",
            "label": "Physical Copy Details",
            "depends_on": "eval:doc.copy_type=='Physical'"
        },
        {
            "fieldname": "total_copies",
            "fieldtype": "Int",
            "label": "Total Copies",
            "default": 1,
            "depends_on": "eval:doc.copy_type=='Physical'"
        },
        {
            "fieldname": "available_copies",
            "fieldtype": "Int",
            "label": "Available Copies",
            "default": 0,
            "read_only": 1,
            "depends_on": "eval:doc.copy_type=='Physical'"
        },
        {
            "fieldname": "location",
            "fieldtype": "Link",
            "options": "Library Shelf",
            "label": "Shelf / Location",
            "depends_on": "eval:doc.copy_type=='Physical'"
        },
        {
            "fieldname": "column_break_2",
            "fieldtype": "Column Break"
        },
        {
            "fieldname": "borrow_period_days",
            "fieldtype": "Int",
            "label": "Borrow Period (Days)",
            "default": 14,
            "depends_on": "eval:doc.copy_type=='Physical'"
        },
        {
            "fieldname": "fine_per_day",
            "fieldtype": "Currency",
            "label": "Fine Per Day",
            "depends_on": "eval:doc.copy_type=='Physical'"
        },
        {
            "fieldname": "section_online",
            "fieldtype": "Section Break",
            "label": "Online Copy Details",
            "depends_on": "eval:doc.copy_type=='Online'"
        },
        {
            "fieldname": "ebook_file",
            "fieldtype": "Attach",
            "label": "eBook File",
            "depends_on": "eval:doc.copy_type=='Online'"
        }
    ],
    "permissions": [
        {
            "role": "System Manager",
            "read": 1,
            "write": 1,
            "create": 1,
            "delete": 1,
            "print": 1,
            "export": 1,
            "report": 1
        }
    ],
    "index_web_pages_for_search": 1
}