{
    "doctype": "DocType",
    "name": "Library Book",
    "module": "Maxedu",
    "custom": 0,
    "istable": 0,
    "autoname": "naming_series:",
    "naming_rule": "By \"Naming Series\" field",
    "field_order": [
        "naming_series",
        "title",
        "isbn",
        "author",
        "edition",
        "column_break_1",
        "publisher",
        "category",
        "language",
        "publication_year",
        "row_break_1",
        "description",
        "row_break_2",
        "tags",
        "column_break_2",
        "cover_image"
    ],
    "fields": [
        {
            "fieldname": "naming_series",
            "fieldtype": "Select",
            "label": "Naming Series",
            "options": "LIB-BOOK-.####",
            "default": "LIB-BOOK-.####",
            "hidden": 1
        },
        {
            "fieldname": "title",
            "fieldtype": "Data",
            "label": "Title",
            "reqd": 1,
            "in_list_view": 1
        },
        {
            "fieldname": "isbn",
            "fieldtype": "Data",
            "label": "ISBN",
            "reqd": 1,
            "unique": 1,
            "in_list_view": 1
        },
        {
            "fieldname": "author",
            "fieldtype": "Data",
            "label": "Author",
            "reqd": 1,
            "in_list_view": 1
        },
        {
            "fieldname": "edition",
            "fieldtype": "Data",
            "label": "Edition"
        },
        {
            "fieldname": "column_break_1",
            "fieldtype": "Column Break"
        },
        {
            "fieldname": "publisher",
            "fieldtype": "Data",
            "label": "Publisher"
        },
        {
            "fieldname": "category",
            "fieldtype": "Link",
            "label": "Category",
            "options": "Library Category"
        },
        {
            "fieldname": "language",
            "fieldtype": "Select",
            "label": "Language",
            "options": "Bengali\nHindi\nEnglish\nSpanish\nFrench\nGerman\nChinese\nJapanese\nOther"
        },
        {
            "fieldname": "publication_year",
            "fieldtype": "Int",
            "label": "Publication Year"
        },
        {
            "fieldname": "row_break_1",
            "fieldtype": "Section Break"
        },
        {
            "fieldname": "description",
            "fieldtype": "Small Text",
            "label": "Description"
        },
        {
            "fieldname": "row_break_2",
            "fieldtype": "Section Break",
            "label": "Media & Tags"
        },
        {
            "fieldname": "tags",
            "fieldtype": "Table MultiSelect",
            "label": "Tags",
            "options": "Library Tag"
        },
        {
            "fieldname": "column_break_2",
            "fieldtype": "Column Break"
        },
        {
            "fieldname": "cover_image",
            "fieldtype": "Attach Image",
            "label": "Cover Image"
        }
    ],
    "permissions": [
        {
            "role": "System Manager",
            "create": 1,
            "delete": 1,
            "email": 1,
            "export": 1,
            "print": 1,
            "read": 1,
            "report": 1,
            "share": 1,
            "write": 1
        }
    ],
    "index_web_pages_for_search": 1
}