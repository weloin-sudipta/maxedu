{
  "doctype": "DocType",
  "name": "Approval Step",
  "module": "Desk Approval",
  "istable": 1,
  "fields": [
    {
      "fieldname": "approved_by",
      "fieldtype": "Select",
      "options": "Role\nUser",
      "label": "Approved By",
      "default": "Role"
    },
    {
      "fieldname": "user",
      "fieldtype": "Link",
      "options": "User",
      "label": "User",
      "depends_on": "eval:doc.approved_by=='User'"
    },
    {
      "fieldname": "role",
      "fieldtype": "Link",
      "options": "Role",
      "label": "Role",
      "depends_on": "eval:doc.approved_by=='Role'"
    },
    {
      "fieldname": "order",
      "fieldtype": "Int",
      "label": "Order"
    },
    {
      "fieldname": "approval_mode",
      "fieldtype": "Select",
      "options": "Any One\nAll",
      "default": "Any One",
      "label": "Approval Mode"
    },
    {
      "fieldname": "is_optional",
      "fieldtype": "Check",
      "label": "Is Optional"
    },
    {
      "fieldname": "fallback_user",
      "fieldtype": "Link",
      "options": "User",
      "label": "Fallback User"
    },
    {
      "fieldname": "fallback_role",
      "fieldtype": "Link",
      "options": "Role",
      "label": "Fallback Role"
    },
    {
      "fieldname": "condition_script",
      "fieldtype": "Small Text",
      "label": "Condition Script"
    }
  ],
  "permissions": [
    {
      "create": 1,
      "delete": 1,
      "email": 1,
      "export": 1,
      "print": 1,
      "read": 1,
      "report": 1,
      "role": "System Manager",
      "share": 1,
      "write": 1
    },
    {
      "create": 1,
      "delete": 1,
      "email": 1,
      "export": 1,
      "print": 1,
      "read": 1,
      "report": 1,
      "role": "Student",
      "share": 1,
      "write": 1
    },
    {
      "create": 1,
      "delete": 1,
      "email": 1,
      "export": 1,
      "print": 1,
      "read": 1,
      "report": 1,
      "role": "Instructor",
      "share": 1,
      "write": 1
    }
  ]
}